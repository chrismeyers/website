---
import '../index.css';
import '../App.css';
import '../assets/vendor/hamburgers/hamburgers.min.css';
import FullNav from '../components/FullNav.astro';
import ThemeShell from '../components/ThemeShell.tsx';
import { SLOGAN } from '../constants.ts';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageTitle = title ? `${title} | ${SLOGAN}` : SLOGAN;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={SLOGAN} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <div class="site-root">
      <FullNav pathname={pathname} />
      <ThemeShell pathname={pathname} client:only="react">
        <slot />
      </ThemeShell>
    </div>
  </body>
</html>
