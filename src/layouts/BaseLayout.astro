---
import '../index.css';
import '../App.css';
import '../assets/vendor/hamburgers/hamburgers.min.css';
import Footer from '../components/Footer.astro';
import FullNav from '../components/FullNav.astro';
import MobileNav from '../components/MobileNav.astro';
import { SLOGAN } from '../constants.ts';
import { absoluteUrl, canonicalPath, pageImageUrl } from '../lib/seo.ts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const { title, description = SLOGAN, image, noindex = false } = Astro.props;
const pageTitle = title ? `${title} | ${SLOGAN}` : SLOGAN;
const pathname = Astro.url.pathname;
const site = Astro.site ?? new URL('https://chrismeyers.net');
const canonicalURL = new URL(canonicalPath(pathname), site);
const ogImage = pageImageUrl(image, site.href);
const ogLogo = absoluteUrl('/og-logo.png', site.href);
const ogTitle = pageTitle;
const twitterCard = 'summary_large_image';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SLOGAN} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:logo" content={ogLogo} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/favicon-192x192.png"
    />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.setAttribute('data-theme', theme);

        const syncToggleAria = () => {
          document.querySelectorAll('.theme-toggle').forEach((toggle) => {
            toggle.setAttribute(
              'aria-checked',
              theme === 'dark' ? 'true' : 'false'
            );
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', syncToggleAria);
        } else {
          syncToggleAria();
        }
      })();
    </script>
    <script>
      import { initTheme } from '../lib/theme.ts';
      initTheme();
    </script>
  </head>
  <body>
    <div class="site-root">
      <FullNav pathname={pathname} />
      <MobileNav pathname={pathname} />
      <slot />
      <Footer />
    </div>
  </body>
</html>
