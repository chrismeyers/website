---
import externalLinkIcon from '../assets/images/icons/link-external.svg?raw';
import githubIcon from '../assets/images/icons/github.svg?raw';
import linkedinIcon from '../assets/images/icons/linkedin.svg?raw';
import mailIcon from '../assets/images/icons/mail.svg?raw';
import moonIcon from '../assets/images/icons/moon.svg?raw';
import playIcon from '../assets/images/icons/play.svg?raw';
import sunIcon from '../assets/images/icons/sun.svg?raw';
import { buildIconSvg } from '../lib/build-icon-svg.ts';

const ICONS = {
  github: githubIcon,
  linkedin: linkedinIcon,
  mail: mailIcon,
  moon: moonIcon,
  sun: sunIcon,
  'link-external': externalLinkIcon,
  play: playIcon,
} as const;

export type IconName = keyof typeof ICONS;

interface Props {
  name: IconName;
  class?: string;
  title?: string;
  ariaLabel?: string;
}

const { name, class: className, title, ariaLabel } = Astro.props;

const svg = buildIconSvg(ICONS[name], { className, title, ariaLabel });
---

<Fragment set:html={svg} />
