---
import logo from '../assets/images/logos/v3/ccm-logo.svg?raw';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span class:list={['logo', className]} set:html={logo} />

<style>
  .logo {
    display: block;
    width: 100%;
    height: 100%;
  }

  .logo :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
