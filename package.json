{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0"
    }
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "CI=true vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --experimental-cli --check '**/*.{ts,js,mjs,cjs,astro}'",
    "format:fix": "prettier --experimental-cli --write '**/*.{ts,js,mjs,cjs,astro}'",
    "check": "astro check",
    "dev": "astro dev",
    "generate": "bin/generate.sh",
    "prebuild": "npm run generate",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "lightgallery": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.7",
    "astro": "^6.4.2",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
