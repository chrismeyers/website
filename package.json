{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "24"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "CI=true vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --experimental-cli --check '**/*.{ts,tsx,js,cjs,jsx}'",
    "format:fix": "prettier --experimental-cli --write '**/*.{ts,tsx,js,cjs,jsx}'",
    "dev": "vite",
    "preview": "vite preview",
    "generate": "bin/generate.sh",
    "build": "tsc --build && vite build"
  },
  "dependencies": {
    "lightgallery": "^2.9.0",
    "lodash": "^4.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-switch": "^7.1.0",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint-react/kit": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vite-plugin-svgr": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
