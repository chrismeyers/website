{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.15.0"
    }
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ci": "CI=true vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --experimental-cli --check '**/*.{ts,tsx,js,mjs,cjs,jsx,astro}'",
    "format:fix": "prettier --experimental-cli --write '**/*.{ts,tsx,js,mjs,cjs,jsx,astro}'",
    "dev": "astro dev",
    "generate": "bin/generate.sh",
    "prebuild": "npm run generate",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "astro": "^6.3.3",
    "lightgallery": "^2.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-switch": "^7.1.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.3",
    "@eslint-react/kit": "^5.7.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  }
}
